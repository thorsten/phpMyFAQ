{% extends 'index.twig' %}

{% block content %}
<div class="row g-5">
  <div class="{{ isAllCategories ? 'col-12' : 'col-md-8' }}">

    <div class="breadcrumb-wrapper">
      {{ breadcrumb | raw }}
    </div>

    <h2 class="mb-4 border-bottom">{{ categoryHeader }}</h2>

    {% if isAllCategories %}
      {% if categoryTree is not empty %}
        {% import 'partials/category-tree.twig' as categoryTreeMacro %}
        <div class="pmf-category-tree-toolbar">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-pmf-expand-all>{{ msgExpandAll }}</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" data-pmf-collapse-all>{{ msgCollapseAll }}</button>
        </div>
        {{ categoryTreeMacro.renderTree(categoryTree) }}
      {% else %}
        {{ categoryEmptyMessage | raw }}
      {% endif %}
    {% else %}
      {{ categoryContent | raw }}
    {% endif %}

    <p>{{ categoryLevelUp | raw }}</p>
  </div>

  {% if not isAllCategories %}
  <div class="col-md-4">
    <div class="position-sticky" style="top: 2rem">
      {% if categoryImage is not empty or categoryDescription is not empty %}
      <div class="p-4 mb-3 pmf-sidebar-card clearfix overflow-hidden">
        {% if categoryImage is not empty %}
        <img src="{{ categoryImage }}" alt="{{ categoryFaqsHeader }}" class="rounded img-fluid float-end m-1">
        {% endif %}
        <h4 class="pmf-sidebar-card-title">{{ categoryFaqsHeader | raw }}</h4>
        <p class="mb-0 small">{{ categoryDescription | raw }}</p>
      </div>
      {% endif %}

      {% if subCategoryContent != null %}
      <div class="p-4 mb-3 pmf-sidebar-card">
        <h4 class="pmf-sidebar-card-title">{{ categorySubsHeader }}</h4>
        {{ subCategoryContent | raw }}
      </div>
      {% endif %}

    </div>
  </div>
  {% endif %}
</div>

{% endblock %}
