{% extends '@admin/index.twig' %}

{% block content %}
  <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 mb-3 border-bottom">
    <h1 class="h2">
      <i aria-hidden="true" class="bi bi-tasks"></i>
      {{ adminHeaderSessionsPerDay }} {{ currentDay }}
    </h1>
    <div class="btn-toolbar mb-2 mb-md-0">
      <a class="btn btn-outline-secondary" href="./statistics/sessions">
        <i aria-hidden="true" class="bi bi-arrow-left"></i> {{ 'ad_sess_back' | translate }}
      </a>
    </div>
  </div>

  <div class="card shadow">
    <h5 class="card-header py-3 d-flex justify-content-between align-items-center">
      <span><i aria-hidden="true" class="bi bi-list-ol"></i> {{ 'ad_sess_count' | translate }}</span>
      <span class="badge bg-primary rounded-pill">{{ sessionData | length }}</span>
    </h5>
    <div class="card-body">
      {% if sessionData | length > 0 %}
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle mb-0">
            <caption class="visually-hidden">{{ adminHeaderSessionsPerDay }} {{ currentDay }}</caption>
            <thead>
              <tr>
                <th scope="col">{{ msgIpAddress }}</th>
                <th scope="col">{{ msgSessionDate }}</th>
                <th scope="col" class="text-end">{{ msgSession }}</th>
              </tr>
            </thead>
            <tbody>
            {% for sid, data in sessionData %}
              <tr>
                <td><code>{{ data.ip }}</code></td>
                <td>{{ data.time | date }}</td>
                <td class="text-end">
                  <a class="btn btn-sm btn-outline-primary" href="./statistics/session/{{ sid }}">
                    <i aria-hidden="true" class="bi bi-eye"></i> {{ 'ad_sess_view' | translate }}
                  </a>
                </td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
      {% else %}
        <div class="text-center text-muted py-4">
          <i aria-hidden="true" class="bi bi-inbox display-6 d-block mb-2"></i>
          {{ 'ad_sess_no_sessions' | translate }}
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
