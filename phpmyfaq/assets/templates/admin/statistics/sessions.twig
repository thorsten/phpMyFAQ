{% extends '@admin/index.twig' %}

{% block content %}
  <div
    class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 mb-3 border-bottom">
    <h1 class="h2">
      <i aria-hidden="true" class="bi bi-list-ol"></i> {{ adminHeaderSessions }}
    </h1>
    <div class="btn-toolbar mb-2 mb-md-0">
      <div class="btn-group">
        <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal"
                data-bs-target="#pmf-clear-visits-modal">
          <i aria-hidden="true" class="bi bi-trash"></i> {{ msgClearVisits }}
        </button>
      </div>
    </div>
  </div>

  {# Key metrics #}
  <section class="row" id="pmf-sessions-metrics">
    <div class="col-xl-3 col-md-6 mb-4">
      <div class="card text-bg-primary shadow h-100 py-2">
        <div class="card-body">
          <div class="row g-0 align-items-center">
            <div class="col">
              <div class="text-uppercase small fw-bold mb-1">{{ msgVisits }}</div>
              <div class="h3 mb-0 fw-bold">{{ numberOfVisits }}</div>
            </div>
            <div class="col-auto">
              <i aria-hidden="true" class="bi bi-people display-6 opacity-50"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
      <div class="card text-bg-success shadow h-100 py-2">
        <div class="card-body">
          <div class="row g-0 align-items-center">
            <div class="col">
              <div class="text-uppercase small fw-bold mb-1">{{ msgVisitsPerDay }}</div>
              <div class="h3 mb-0 fw-bold">{{ visitsPerDay }}</div>
            </div>
            <div class="col-auto">
              <i aria-hidden="true" class="bi bi-graph-up-arrow display-6 opacity-50"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
      <div class="card text-bg-info shadow h-100 py-2">
        <div class="card-body">
          <div class="row g-0 align-items-center">
            <div class="col">
              <div class="text-uppercase small fw-bold mb-1">{{ msgDays }}</div>
              <div class="h3 mb-0 fw-bold">{{ numberOfDays }}</div>
            </div>
            <div class="col-auto">
              <i aria-hidden="true" class="bi bi-calendar3 display-6 opacity-50"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
      <div class="card text-bg-secondary shadow h-100 py-2">
        <div class="card-body">
          <div class="row g-0 align-items-center">
            <div class="col">
              <div class="text-uppercase small fw-bold mb-1">
                {{ msgFirstDate }} &ndash; {{ msgLastDate }}
              </div>
              <div class="fw-bold">{{ firstDate }}</div>
              <div class="fw-bold">{{ lastDate }}</div>
            </div>
            <div class="col-auto">
              <i aria-hidden="true" class="bi bi-clock-history display-6 opacity-50"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {# Visits chart + browse a single day #}
  <section class="row">
    <div class="col-lg-8 mb-4">
      <div class="card shadow h-100">
        <h5 class="card-header py-3 d-flex justify-content-between align-items-center">
          <span><i aria-hidden="true" class="bi bi-bar-chart"></i> {{ msgVisits }}</span>
          <div
            class="btn-group btn-group-sm"
            role="group"
            id="pmf-visits-range"
            aria-label="{{ 'msgVisitsRange' | translate | default('Visitor date range') }}"
          >
            <button type="button" class="btn btn-outline-primary" data-pmf-range="7">7</button>
            <button type="button" class="btn btn-outline-primary active" data-pmf-range="30">30</button>
            <button type="button" class="btn btn-outline-primary" data-pmf-range="90">90</button>
          </div>
        </h5>
        <div class="card-body">
          <div class="pmf-charts">
            <div id="pmf-chart-visits-skeleton" class="pmf-chart-skeleton" aria-hidden="true"></div>
            <canvas id="pmf-chart-visits" width="200" height="150"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-4 mb-4">
      <div class="card shadow h-100">
        <h5 class="card-header py-3">
          <i aria-hidden="true" class="bi bi-calendar-week"></i> {{ msgSessionBrowse }}
        </h5>
        <div class="card-body">
          <form method="post" id="pmf-admin-form-session" action="">
            <label for="day" class="form-label">{{ msgSessionBrowse }}</label>
            <div class="input-group">
              <select name="day" id="day" class="form-select">
                {{ renderedDaySelector | raw }}
              </select>
              <button class="btn btn-primary" type="button" id="pmf-admin-session-day">
                <i aria-hidden="true" class="bi bi-search"></i> {{ buttonOkay }}
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  {# Session management + CSV export #}
  <section class="row">
    <div class="col-lg-6 mb-4">
      <div class="card shadow h-100">
        <h5 class="card-header py-3">
          <i aria-hidden="true" class="bi bi-trash"></i> {{ msgSessionManagement }}
        </h5>
        <div class="card-body">
          <form>
            <input type="hidden" name="statdelete" id="statdelete" value="delete">
            {{ csrfTokenSessions | raw }}
            <label class="form-label" for="month">{{ msgChooseMonth }}</label>
            <div class="input-group">
              <select name="month" id="month" class="form-select">
                {{ renderedMonthSelector | raw }}
              </select>
              <button class="btn btn-outline-danger" type="button" id="pmf-admin-delete-sessions">
                <i aria-hidden="true" class="bi bi-trash"></i> {{ buttonDeleteMonth }}
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-6 mb-4">
      <div class="card shadow h-100">
        <h5 class="card-header py-3">
          <i aria-hidden="true" class="bi bi-file-earmark-arrow-down"></i> {{ 'msgExportSessionsAsCSV' | translate }}
        </h5>
        <div class="card-body">
          <form>
            <input type="hidden" id="csrf" value="{{ csrfTokenExport }}"/>
            <div class="row g-3 align-items-end">
              <div class="col-sm-6">
                <label for="firstHour" class="form-label">{{ 'msgExportSessionsFrom' | translate }}</label>
                <input type="date" class="form-control" min="{{ datePickerMinDate }}" max="{{ dateToday }}"
                       id="firstHour"/>
              </div>
              <div class="col-sm-6">
                <label for="lastHour" class="form-label">{{ 'msgExportSessionsTo' | translate }}</label>
                <input type="date" class="form-control" id="lastHour" min="{{ datePickerMinDate }}"
                       max="{{ dateToday }}"/>
              </div>
            </div>
            <div class="mt-3 d-flex justify-content-end">
              <button class="btn btn-primary" type="submit" id="exportSessions">
                <i aria-hidden="true" class="bi bi-file-earmark-arrow-down"></i> {{ 'msgExportSessions' | translate }}
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  {# Clear all visits confirmation #}
  <div class="modal fade" id="pmf-clear-visits-modal" tabindex="-1" aria-labelledby="pmf-clear-visits-modal-label"
       aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h1 class="modal-title fs-5" id="pmf-clear-visits-modal-label">
            <i aria-hidden="true" class="bi bi-exclamation-triangle-fill text-danger"></i> {{ msgClearVisits }}
          </h1>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          {{ 'ad_clear_all_visits_confirm' | translate }}
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            {{ 'ad_gen_cancel' | translate }}
          </button>
          <button type="button" class="btn btn-danger" id="pmf-admin-clear-visits"
                  data-pmf-csrf="{{ csrfTokenClearVisits }}" data-bs-dismiss="modal">
            <i aria-hidden="true" class="bi bi-trash"></i> {{ msgClearVisits }}
          </button>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
