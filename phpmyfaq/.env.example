# phpMyFAQ Environment Configuration

# Application Environment
# Options: production, development, staging, demo
APP_ENV=production

# Debug Mode
# Enable detailed error messages and debug tools
# NOTE: Cache is automatically disabled when DEBUG=true (for development)
DEBUG=false

# Debug Query Logging
# Log all database queries (performance impact)
DEBUG_LOG_QUERIES=false

# Error Log
# Where to write error logs
ERROR_LOG=php://stderr

# Routing Configuration
# Enable route caching for better performance in production
# Route caching uses reflection to discover routes, then caches the result
# Disable in development to see route changes immediately
ROUTING_CACHE_ENABLED=true

# Route Cache Directory (optional)
# Default: {PMF_ROOT_DIR}/cache/routes
# Only override if you need a custom location (must be an absolute path)
# ROUTING_CACHE_DIR=/custom/path/to/cache

# Configuration Cache
# Caches the faqconfig table in the filesystem cache pool so installs without
# Redis do not scan the full configuration table on every request. Changes made
# through the admin UI invalidate the cache immediately; on multi-server setups
# other nodes pick up changes after at most 5 minutes. Automatically disabled
# in debug mode and on development versions.
CONFIG_CACHE_ENABLED=true

# Compiled Service Container Cache
# Compiles the DI container once and caches it as a PHP class, so services.php
# is not re-parsed on every request. Automatically disabled in debug mode and
# on development versions. Delete {PMF_ROOT_DIR}/cache/container after upgrades.
CONTAINER_CACHE_ENABLED=true

# Container Cache Directory (optional)
# Default: {PMF_ROOT_DIR}/cache/container
# Only override if you need a custom location (must be an absolute path)
# CONTAINER_CACHE_DIR=/custom/path/to/cache

# Twig Template Compile Cache
# Caches compiled Twig templates as PHP files for better performance.
# Automatically disabled in debug mode and on development versions; changed
# templates are recompiled automatically (auto_reload).
TWIG_CACHE_ENABLED=true

# Twig Cache Directory (optional)
# Default: {PMF_ROOT_DIR}/cache/twig
# Only override if you need a custom location (must be an absolute path)
# TWIG_CACHE_DIR=/custom/path/to/cache

# ElasticSearch and OpenSearch Configuration
OPENSEARCH_BASE_URI=http://127.0.0.1:9201
ELASTICSEARCH_BASE_URI=http://127.0.0.1:9200
SEARCH_WAIT_TIMEOUT=15
