{
  "name": "thorsten/phpmyfaq",
  "description": "Open source FAQ web application for PHP 8.4+ with multi-database support, full-text search, user management, and a REST API",
  "keywords": [
    "phpMyFAQ",
    "FAQ",
    "Knowledge-Base",
    "Helpdesk",
    "Self-Service",
    "Question-Answer",
    "Content-Management",
    "Full-Text-Search",
    "Elasticsearch",
    "Opensearch",
    "Multi-Language",
    "REST-API",
    "PHP",
    "MCP"
  ],
  "homepage": "https://www.phpmyfaq.de",
  "license": "MPL-2.0",
  "type": "application",
  "authors": [
    {
      "name": "Thorsten Rinne",
      "email": "thorsten@phpmyfaq.de"
    }
  ],
  "require": {
    "php": ">=8.4.0",
    "ext-curl": "*",
    "ext-fileinfo": "*",
    "ext-filter": "*",
    "ext-gd": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "ext-sodium": "*",
    "ext-xml": "*",
    "ext-xmlwriter": "*",
    "ext-zip": "*",
    "2tvenom/cborencode": "~1.0.2",
    "aws/aws-sdk-php": "~3.374.0",
    "elasticsearch/elasticsearch": "~8.19.0",
    "endroid/qr-code": "~6.1.3",
    "guzzlehttp/guzzle": "~7.10.0",
    "league/commonmark": "~2.8.2",
    "league/oauth2-server": "~9.3.0",
    "mcp/sdk": "~0.4.0",
    "minishlink/web-push": "~10.0.3",
    "monolog/monolog": "~3.10.0",
    "myclabs/deep-copy": "~1.13.4",
    "opensearch-project/opensearch-php": "~2.6.0",
    "phpseclib/phpseclib": "~3.0.50",
    "robthree/twofactorauth": "~3.0.3",
    "symfony/cache": "~8.0.7",
    "symfony/config": "~8.0.7",
    "symfony/console": "~8.0.7",
    "symfony/dependency-injection": "~8.0.7",
    "symfony/dotenv": "~8.0.7",
    "symfony/error-handler": "~8.0.4",
    "symfony/event-dispatcher": "~8.0.4",
    "symfony/html-sanitizer": "~8.0.7",
    "symfony/http-client": "~8.0.7",
    "symfony/http-foundation": "~8.0.7",
    "symfony/http-kernel": "~8.0.7",
    "symfony/mailer": "~8.0.6",
    "symfony/rate-limiter": "~8.0.7",
    "symfony/routing": "~8.0.6",
    "symfony/uid": "~8.0.4",
    "tecnickcom/tcpdf": "~6.11.2",
    "tivie/htaccess-parser": "~0.4.0",
    "twig/intl-extra": "~3.24.0",
    "twig/twig": "~3.24.0"
  },
  "require-dev": {
    "carthage-software/mago": "~1.15.3",
    "doctrine/instantiator": "~2.1.0",
    "mikey179/vfsstream": "~1.6.12",
    "phpdocumentor/reflection-docblock": "~5.6.7",
    "phpunit/phpunit": "~13.0.5",
    "rector/rector": "~2.3.9",
    "symfony/browser-kit": "~8.0.4",
    "symfony/css-selector": "~8.0.6",
    "symfony/yaml": "~8.0.6",
    "zircote/swagger-php": "~6.0.6"
  },
  "suggest": {
    "ext-bcmath": "*",
    "ext-frankenphp": "*",
    "ext-gmp": "*",
    "ext-ldap": "*",
    "ext-pdo": "*",
    "ext-pgsql": "*",
    "ext-sqlite3": "*",
    "ext-sqlsrv": "*"
  },
  "config": {
    "platform": {
      "php": "8.4.1"
    },
    "process-timeout": 0,
    "secure-http": true,
    "vendor-dir": "phpmyfaq/src/libs",
    "bin-dir": "phpmyfaq/src/libs/bin",
    "allow-plugins": {
      "carthage-software/mago": true,
      "php-http/discovery": true
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "phpMyFAQ\\": "./phpmyfaq/src/phpMyFAQ"
    }
  },
  "minimum-stability": "stable",
  "scripts": {
    "analyze": "./phpmyfaq/src/libs/bin/mago analyze",
    "format": "./phpmyfaq/src/libs/bin/mago format",
    "format:fix": "./phpmyfaq/src/libs/bin/mago format --fix",
    "lint": "./phpmyfaq/src/libs/bin/mago lint",
    "lint:fix": "./phpmyfaq/src/libs/bin/mago lint --fix",
    "openapi:json": "./phpmyfaq/src/libs/bin/openapi -b ./phpmyfaq/src/libs/autoload.php -f json ./phpmyfaq/src/phpMyFAQ -o docs/openapi.json",
    "openapi:yaml": "./phpmyfaq/src/libs/bin/openapi -b ./phpmyfaq/src/libs/autoload.php ./phpmyfaq/src/phpMyFAQ -o docs/openapi.yaml",
    "refactor": "./phpmyfaq/src/libs/bin/rector",
    "refactor:dryrun": "./phpmyfaq/src/libs/bin/rector --dry-run",
    "test": "./phpmyfaq/src/libs/bin/phpunit --no-coverage",
    "test:coverage": "./phpmyfaq/src/libs/bin/phpunit --coverage-text",
    "test:coverage-html": "./phpmyfaq/src/libs/bin/phpunit --coverage-html coverage",
    "version:get": "php scripts/get-version.php",
    "version:sync": "pnpm version $(php scripts/get-version.php) --no-git-tag-version --allow-same-version",
    "version:check": "php scripts/check-version.php"
  },
  "support": {
    "docs": "https://phpmyfaq.readthedocs.io/",
    "forum": "https://forum.phpmyfaq.de/",
    "issues": "https://github.com/thorsten/phpMyFAQ/issues",
    "source": "https://github.com/thorsten/phpMyFAQ"
  }
}
